# Required — OMOPHub API key (get one at https://omophub.com)
OMOPHUB_API_KEY=

# Optional — Override API base URL (default: https://api.omophub.com/v1)
# OMOPHUB_BASE_URL=https://api.omophub.com/v1

# Optional — Opt out of analytics headers (default: false)
# OMOPHUB_ANALYTICS_OPTOUT=true

# Optional — Log level: debug, info, warn, error (default: info)
# OMOPHUB_LOG_LEVEL=info

# Optional — Enable health endpoint on this port (disabled by default)
# HEALTH_PORT=8080
